{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "dashboard.clearbalance.xyz" }],
      "destination": "/dashboard/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
